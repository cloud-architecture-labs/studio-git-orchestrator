# ==============================================================================
# STUDIO GIT ORCHESTRATOR - GLOBAL IGNORE CONFIGURATION
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. SECURITY & CREDENTIALS
# ------------------------------------------------------------------------------
# EXPLICITLY blocks the local orchestrator executable to prevent accidental 
# exposure of GitHub Personal Access Tokens and Gemini API Keys.
orchestrator.sh
.env
.env.*
*.pem
*.key
credentials.json
local_keys.json

# ------------------------------------------------------------------------------
# 2. PYTHON VIRTUAL ENVIRONMENTS & ARTIFACTS
# ------------------------------------------------------------------------------
# Prevents Git from tracking massive dependency folders and compiled bytecode.
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.venv/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ------------------------------------------------------------------------------
# 3. OS & SYSTEM FILES
# ------------------------------------------------------------------------------
# Ignores ghost files generated by macOS and Windows operating systems.
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
Thumbs.db
ehthumbs.db
Desktop.ini

# ------------------------------------------------------------------------------
# 4. IDE & EDITOR CONFIGURATIONS
# ------------------------------------------------------------------------------
# Ignores localized settings generated by standard IDEs to prevent developer conflicts.
.vscode/
.idea/
*.swp
*.swo